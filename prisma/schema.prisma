generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id             Int      @id @default(autoincrement())
  title          String
  description    String?
  style          String?
  sku            String   @unique
  price          Float
  currencyId     String   @default("CLP")
  currencyFormat String   @default("$")
  installments   Int      @default(1)
  isFreeShipping Boolean  @default(false)
  availableSizes String   @default("")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
